{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "biopass-rs",
  "identifier": "biopass-rs",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Biopass-rs",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.local/share/biopass-rs/**", "$DATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["fprintd", "curl", "libwebkit2gtk-4.1-0"],
        "postInstallScript": "scripts/deb/postinst",
        "files": {
          "/lib/security/libbiopass_rs_pam.so": "../../../target/release/libbiopass_rs_pam.so",
          "/usr/bin/biopass-rs-helper": "../../../target/release/biopass-rs-helper",
          "/etc/ld.so.conf.d/biopass-rs.conf": "scripts/ldconf",
          "/usr/share/pam-configs/biopass-rs": "scripts/pam.conf"
        }
      },
      "rpm": {
        "depends": ["fprintd", "curl"],
        "postInstallScript": "scripts/rpm/postinst",
        "postRemoveScript": "scripts/rpm/postrm",
        "files": {
          "/lib64/security/libbiopass_rs_pam.so": "../../../target/release/libbiopass_rs_pam.so",
          "/usr/bin/biopass-rs-helper": "../../../target/release/biopass-rs-helper",
          "/etc/ld.so.conf.d/biopass-rs.conf": "scripts/ldconf",
          "/usr/share/pam-configs/biopass-rs": "scripts/pam.conf"
        }
      }
    }
  }
}
