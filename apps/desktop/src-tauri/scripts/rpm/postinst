#!/bin/bash
# postinst-rpm - RPM package post-install script.
# In RPM, $1 is the number of installed versions after the transaction.

set -e

HELPER="/usr/bin/biopass-rs-helper"
if [ -x "$HELPER" ]; then
    echo "Biopass-rs: Running post-install tasks..."
    "$HELPER" install || true
else
    echo "Biopass-rs: Warning - biopass-rs-helper not found, skipping post-install tasks" >&2
fi

exit 0
