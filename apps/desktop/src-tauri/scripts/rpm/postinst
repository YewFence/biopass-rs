#!/bin/bash
# postinst-rpm - RPM package post-install script.
# In RPM, $1 is the number of installed versions after the transaction.
#
# System-level setup only. User data (config and face models) is intentionally
# NOT initialized here: %post runs as root with no way to know which user will
# actually use biopass. The user runs `biopass-rs-helper install` themselves
# after logging in.

set -e

# Refresh the linker cache so the PAM module's library path is picked up.
ldconfig

cat >&2 <<'EOF'

================================================================
 biopass-rs is now installed. One step left to finish setup.

 Log in as the user who will use biopass, then run:

     biopass-rs-helper install

 This initializes that user's config and downloads the face models.
================================================================

EOF

exit 0
