#!/bin/bash
# postinst — Debian package post-installation maintainer script.
# Runs after all files in the .deb package have been unpacked.
#
# System-level setup only. User data (config and face models) is intentionally
# NOT initialized here: postinst runs as root with no way to know which user
# will actually use biopass. The user runs `biopass-rs-helper install`
# themselves after logging in.

set -e

case "$1" in
    configure)
        # Refresh the linker cache so the PAM module's library path is picked up.
        ldconfig

        cat >&2 <<'EOF'

================================================================
 biopass-rs is now installed. One step left to finish setup.

 Log in as the user who will use biopass, then run:

     biopass-rs-helper install

 This initializes that user's config and downloads the face models.
================================================================

EOF
        ;;
    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
    *)
        echo "postinst called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

exit 0
